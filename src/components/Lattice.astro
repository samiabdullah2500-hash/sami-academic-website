---
/**
 * Signature element: a subtle hexagonal (wurtzite-inspired) lattice,
 * echoing the crystal structure of ZnO. Used as the hero backdrop.
 */
---
<div class="lattice" aria-hidden="true">
  <svg width="100%" height="100%">
    <defs>
      <pattern id="hex" width="56" height="97" patternUnits="userSpaceOnUse" patternTransform="scale(1.15)">
        <polygon points="28,2 54,17 54,49 28,64 2,49 2,17" fill="none" stroke="currentColor" stroke-width="1"/>
        <polygon points="28,2 54,17 54,49 28,64 2,49 2,17" fill="none" stroke="currentColor" stroke-width="1" transform="translate(28,48)"/>
        <polygon points="28,2 54,17 54,49 28,64 2,49 2,17" fill="none" stroke="currentColor" stroke-width="1" transform="translate(-28,48)"/>
        <circle cx="28" cy="2" r="2.2" fill="currentColor"/>
        <circle cx="2" cy="17" r="2.2" fill="currentColor"/>
        <circle cx="54" cy="49" r="2.2" fill="currentColor"/>
      </pattern>
      <radialGradient id="fade" cx="72%" cy="30%" r="75%">
        <stop offset="0%" stop-color="white" stop-opacity="0.9"/>
        <stop offset="100%" stop-color="white" stop-opacity="0"/>
      </radialGradient>
      <mask id="fade-mask"><rect width="100%" height="100%" fill="url(#fade)"/></mask>
    </defs>
    <rect width="100%" height="100%" fill="url(#hex)" mask="url(#fade-mask)"/>
  </svg>
</div>

<style>
  .lattice {
    position: absolute; inset: 0; z-index: 0;
    color: var(--accent);
    opacity: 0.13;
    pointer-events: none;
  }
  :global([data-theme='dark']) .lattice { opacity: 0.18; }
</style>
