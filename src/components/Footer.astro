---
import { links, profile } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
const social = [
  { label: 'GitHub', href: links.github },
  { label: 'Email', href: links.email.includes('@') ? `mailto:${links.email}` : links.email },
  { label: 'LinkedIn', href: links.linkedin },
].filter((s) => s.href && !s.href.startsWith('[ADD'));
---
<footer class="site-footer">
  <div class="wrap inner">
    <div>
      <p class="name">{profile.name} <span lang="ar" class="ar">{profile.nameArabic}</span></p>
      <p class="sub">{profile.role}</p>
    </div>
    <nav aria-label="Footer">
      <a href={`${base}/research/`}>Research</a>
      <a href={`${base}/nanosami/`}>NanoSami</a>
      <a href={`${base}/blog/`}>Blog</a>
      <a href={`${base}/contact/`}>Contact</a>
      {social.map((s) => <a href={s.href} rel="me noopener">{s.label}</a>)}
    </nav>
  </div>
  <div class="wrap legal">
    <p>© {year} {profile.name}. Built with Astro.</p>
  </div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--line); margin-top: 60px; background: var(--surface); }
  .inner { display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap; padding-top: 34px; padding-bottom: 20px; }
  .name { font-family: var(--font-display); font-weight: 600; }
  .ar { color: var(--muted); margin-inline-start: 10px; font-weight: 400; }
  .sub { color: var(--muted); font-size: 0.88rem; }
  nav { display: flex; gap: 18px; flex-wrap: wrap; align-items: center; }
  nav a { color: var(--muted); font-size: 0.9rem; }
  nav a:hover { color: var(--accent); }
  .legal { padding-bottom: 26px; color: var(--muted); font-size: 0.8rem; font-family: var(--font-mono); }
</style>
