---
import Base from '../layouts/Base.astro';
import { researchInterests, techniques, publications } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Research" description="Research interests: nanomaterials, ZnO nanoparticles, sol-gel synthesis, and materials characterization.">
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Research</p>
        <h1>Research Profile</h1>
        <p>
          My research sits at the intersection of experimental nanoscience and computational
          analysis: synthesizing ZnO nanoparticles by sol-gel methods, studying how the fuel ratio
          shapes their properties, and building deterministic software to analyze the resulting data.
        </p>
      </div>

      <h2 class="sub">Research interests</h2>
      <div class="grid-3">
        {researchInterests.map((r) => (
          <div class="card"><h3>{r.title}</h3><p>{r.note}</p></div>
        ))}
      </div>

      <h2 class="sub">Characterization techniques</h2>
      <div class="chips big-chips">
        {techniques.map((t) => <span class="chip chip-accent">{t}</span>)}
      </div>

      <h2 class="sub">Current work</h2>
      <div class="prose">
        <p>
          <strong>Effect of fuel ratio on ZnO nanoparticle properties.</strong>
          [ADD: 2–4 sentences describing your current M.Sc. work in your own words —
          what you synthesize, what you measure, and what question you are trying to answer.
          Do not state results until they are real and final.]
        </p>
      </div>

      <h2 class="sub">Publications</h2>
      {publications.length === 0 ? (
        <div class="card empty">
          <p>
            Publications will be listed here as they appear. In the meantime, my ongoing work
            is documented on the <a href={`${base}/blog/`}>research blog</a> and in
            <a href={`${base}/projects/`}>open-source projects</a>.
          </p>
        </div>
      ) : (
        <ul class="pubs">
          {publications.map((p) => (
            <li class="card">
              <h3>{p.link ? <a href={p.link}>{p.title}</a> : p.title}</h3>
              <p>{p.venue} · {p.year}</p>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Base>

<style>
  .sub { margin: 56px 0 20px; }
  .big-chips .chip { font-size: 0.86rem; padding: 7px 16px; }
  .empty { max-width: 44rem; }
  .pubs { list-style: none; display: grid; gap: 14px; }
</style>
