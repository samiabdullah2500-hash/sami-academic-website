---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const categories = [...new Set(posts.map((p) => p.data.category))];
---
<Base title="Blog" description="Research notes on nanotechnology, ZnO nanoparticles, materials characterization, and scientific software.">
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Blog</p>
        <h1>Research Blog</h1>
        <p>
          Notes from the lab and the terminal: nanotechnology, ZnO nanoparticles,
          characterization methods, data analysis, AI in research, and NanoSami development.
        </p>
      </div>

      {categories.length > 0 && (
        <div class="chips cats">
          {categories.map((c) => <span class="chip chip-accent">{c}</span>)}
        </div>
      )}

      <div class="grid-2">
        {posts.map((p) => <PostCard post={p} />)}
      </div>

      {posts.length === 0 && (
        <div class="card"><p>No posts yet — the first articles are on their way.</p></div>
      )}
    </div>
  </section>
</Base>

<style>
  .cats { margin-bottom: 28px; }
</style>
