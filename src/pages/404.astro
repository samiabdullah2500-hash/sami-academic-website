---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Page not found">
  <section class="section">
    <div class="wrap" style="text-align:center; padding-top:60px; padding-bottom:60px;">
      <p class="eyebrow" style="justify-content:center">404</p>
      <h1>Page not found</h1>
      <p style="color:var(--muted); margin-top:12px;">This page doesn't exist — like a forbidden energy state.</p>
      <p style="margin-top:28px;"><a class="btn btn-primary" href={`${base}/`}>Back to home</a></p>
    </div>
  </section>
</Base>
