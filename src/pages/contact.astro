---
import Base from '../layouts/Base.astro';
import { profile, links } from '../data/site';
const rows = [
  { label: 'Email', value: links.email, href: links.email.includes('@') ? `mailto:${links.email}` : undefined },
  { label: 'GitHub', value: links.github, href: links.github },
  { label: 'LinkedIn', value: links.linkedin, href: links.linkedin },
  { label: 'Google Scholar', value: links.googleScholar, href: links.googleScholar },
  { label: 'ORCID', value: links.orcid, href: links.orcid },
].filter((r) => r.value);
---
<Base title="Contact" description={`Contact ${profile.name}.`}>
  <section class="section">
    <div class="wrap narrow">
      <div class="section-head">
        <p class="eyebrow">Contact</p>
        <h1>Get in touch</h1>
        <p>
          I'm happy to talk about nanomaterials research, ZnO synthesis and characterization,
          scientific software, or collaboration around NanoSami.
        </p>
      </div>

      <dl>
        {rows.map((r) => (
          <div class="def-row">
            <dt>{r.label}</dt>
            <dd>
              {r.href && !r.value.startsWith('[ADD')
                ? <a href={r.href}>{r.value}</a>
                : <span class="pending">{r.value}</span>}
            </dd>
          </div>
        ))}
      </dl>

      <p class="hint">
        Entries marked <code>[ADD: ...]</code> are placeholders — update them in
        <code>src/data/site.ts</code>.
      </p>
    </div>
  </section>
</Base>

<style>
  .narrow { max-width: 700px; }
  .pending { color: var(--muted); font-family: var(--font-mono); font-size: 0.9rem; }
  .hint { margin-top: 40px; color: var(--muted); font-size: 0.85rem; }
</style>
