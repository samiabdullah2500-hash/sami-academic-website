---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---
<Base title="Projects" description="Open-source scientific software and research projects.">
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Projects</p>
        <h1>Projects</h1>
        <p>
          Software I build for research — with a focus on reproducibility, offline operation,
          and tools that respect how laboratories actually work.
        </p>
      </div>
      <div class="grid-2">
        {projects.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>
</Base>
