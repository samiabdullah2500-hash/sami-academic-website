---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}
const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const ok = (v?: string) => v && !v.startsWith('[ADD');
---
<Base title={d.title} description={d.description}>
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Project</p>
        <h1>{d.title}</h1>
        <p>{d.description}</p>
        <div class="meta">
          <span class={`status status-${d.status.replace(' ', '.')}`}>{d.status}</span>
          <div class="chips">{d.technologies.map((t) => <span class="chip">{t}</span>)}</div>
        </div>
        <div class="links">
          {ok(d.github) && <a class="btn btn-ghost" href={d.github}>GitHub</a>}
          {ok(d.demo) && <a class="btn btn-ghost" href={d.demo}>Live demo</a>}
          {ok(d.docs) && <a class="btn btn-ghost" href={d.docs}>Documentation</a>}
        </div>
      </div>

      {d.gallery.length > 0 && (
        <div class="gallery grid-2">
          {d.gallery.map((src) => <img src={`${base}${src}`} alt={`${d.title} screenshot`} loading="lazy" />)}
        </div>
      )}

      <article class="prose">
        <Content />
      </article>

      <p class="back"><a href={`${base}/projects/`}>← All projects</a></p>
    </div>
  </section>
</Base>

<style>
  .meta { display: flex; align-items: center; gap: 16px; margin-top: 18px; flex-wrap: wrap; }
  .links { display: flex; gap: 12px; margin-top: 20px; flex-wrap: wrap; }
  .gallery { margin-bottom: 40px; }
  .gallery img { border: 1px solid var(--line); border-radius: var(--radius); }
  .back { margin-top: 48px; font-family: var(--font-display); font-weight: 600; }
</style>
